{
  "name": "physical-ai",
  "displayName": "Physical AI",
  "description": "Podman Desktop extension for Physical AI robotics development",
  "version": "0.1.0",
  "icon": "icon.png",
  "publisher": "redhat",
  "license": "Apache-2.0",
  "engines": {
    "podman-desktop": ">=1.28.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "physical-ai.open",
        "title": "Physical AI: Open Dashboard"
      }
    ]
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "watch": "vite --mode development build -w"
  },
  "devDependencies": {
    "@podman-desktop/api": "1.12.0",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "5.5.4",
    "vite": "8.0.16",
    "vitest": "^4.1.0"
  }
}
