{
  "name": "physical-ai",
  "displayName": "Physical AI",
  "description": "Podman Desktop extension for Physical AI robotics development",
  "version": "0.1.0",
  "icon": "icon.png",
  "publisher": "redhat",
  "license": "Apache-2.0",
  "engines": {
    "podman-desktop": ">=1.28.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "physical-ai.open",
        "title": "Physical AI: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Physical AI",
      "properties": {
        "physical-ai.defaultNamespace": {
          "type": "string",
          "default": "ecosystem-appeng",
          "description": "Default Quay.io namespace for browsing and building images"
        },
        "physical-ai.simulationRobot": {
          "type": "string",
          "default": "turtlebot3",
          "description": "Robot type for simulation (e.g. turtlebot3)"
        },
        "physical-ai.simulationDistro": {
          "type": "string",
          "default": "humble",
          "description": "ROS distro for simulation (currently only humble has a bundled simulation image)"
        },
        "physical-ai.simulationMiddleware": {
          "type": "string",
          "default": "dds",
          "description": "Middleware for simulation (dds or zenoh)"
        },
        "physical-ai.simulationEngine": {
          "type": "string",
          "default": "gazebo",
          "description": "Simulation engine (e.g. gazebo)"
        },
        "physical-ai.simulationBaseImage": {
          "type": "string",
          "enum": ["sloretz", "osrf"],
          "enumDescriptions": [
            "ghcr.io/sloretz multi-arch Humble desktop (recommended on Apple Silicon)",
            "docker.io/osrf official Humble desktop (amd64 only)"
          ],
          "default": "sloretz",
          "description": "Base image preset for simulation builds"
        }
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "watch": "vite --mode development build -w"
  },
  "devDependencies": {
    "@podman-desktop/api": "1.12.0",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "5.5.4",
    "vite": "8.0.16",
    "vitest": "^4.1.0"
  }
}
