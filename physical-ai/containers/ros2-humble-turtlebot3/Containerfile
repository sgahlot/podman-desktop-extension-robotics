FROM ghcr.io/sloretz/ros:humble-desktop

LABEL org.opencontainers.image.title="ROS2 Humble TurtleBot3 Simulation" \
      org.opencontainers.image.description="ROS2 Humble with TurtleBot3, Gazebo, and Nav2 for simulation" \
      org.opencontainers.image.vendor="Red Hat" \
      org.opencontainers.image.source="https://github.com/redhat-appeng/physical-ai"

# Install Gazebo, ros-gz bridge, Nav2, and build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    lsb-release \
    wget \
    gnupg \
    curl \
    git \
    python3-colcon-common-extensions \
    && rm -rf /var/lib/apt/lists/*

# Add Gazebo package repository
RUN wget -q https://packages.osrfoundation.org/gazebo.gpg \
      -O /usr/share/keyrings/pkgs-osrf-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/pkgs-osrf-archive-keyring.gpg] http://packages.osrfoundation.org/gazebo/ubuntu-stable $(lsb_release -cs) main" \
      > /etc/apt/sources.list.d/gazebo-stable.list

# Install Gazebo packages and Nav2
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-humble-ros-gz \
    ros-humble-nav2-bringup \
    && rm -rf /var/lib/apt/lists/*

# Clone TurtleBot3 packages
RUN mkdir -p /root/turtlebot3_ws/src \
    && cd /root/turtlebot3_ws/src \
    && git clone -b humble https://github.com/ROBOTIS-GIT/turtlebot3.git \
    && git clone -b humble https://github.com/ROBOTIS-GIT/turtlebot3_msgs.git \
    && git clone -b humble https://github.com/ROBOTIS-GIT/DynamixelSDK.git \
    && git clone -b humble https://github.com/ROBOTIS-GIT/turtlebot3_simulations.git

# Build TurtleBot3 workspace (skip turtlebot3_gazebo — uses classic Gazebo, not gz-sim)
RUN . /opt/ros/humble/setup.sh \
    && cd /root/turtlebot3_ws \
    && touch src/turtlebot3_simulations/turtlebot3_gazebo/COLCON_IGNORE \
    && colcon build --symlink-install --parallel-workers 2

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV TURTLEBOT3_MODEL=burger

WORKDIR /root/turtlebot3_ws

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
