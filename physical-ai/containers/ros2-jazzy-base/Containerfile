FROM docker.io/library/ros:jazzy-ros-base@sha256:31daab66eef9139933379fb67159449944f4e2dcf2e22c2d12cc715f29873e0f

LABEL org.opencontainers.image.title="ROS2 Jazzy Base" \
      org.opencontainers.image.description="Fedora-targeted ROS2 Jazzy development base image (Ubuntu interim)" \
      org.opencontainers.image.vendor="Red Hat" \
      org.opencontainers.image.source="https://github.com/redhat-appeng/physical-ai"

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-colcon-common-extensions \
    python3-rosdep \
    python3-vcstool \
    build-essential \
    cmake \
    git \
    && rosdep init || true \
    && rosdep update \
    && rm -rf /var/lib/apt/lists/*

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /ros2_ws

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
