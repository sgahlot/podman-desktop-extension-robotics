COPY packages/backend/README.md /extension/

FROM scratch

LABEL org.opencontainers.image.title="Physical AI" \
      org.opencontainers.image.description="Podman Desktop extension for Physical AI robotics development" \
      org.opencontainers.image.vendor="Red Hat" \
      io.podman-desktop.api.version=">= 1.28.0"

COPY --from=builder /extension /extension
